{
  "name": "@swarm/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/server.ts",
    "./server": "./src/server.ts",
    "./server-user": "./src/server-user.ts",
    "./http": "./src/http.ts",
    "./stdio": "./src/stdio.ts",
    "./http/*": "./src/http/*.ts",
    "./tools/credential-bindings": "./src/tools/credential-bindings/index.ts",
    "./tools/kv": "./src/tools/kv/index.ts",
    "./tools/mcp-servers": "./src/tools/mcp-servers/index.ts",
    "./tools/prompt-templates": "./src/tools/prompt-templates/index.ts",
    "./tools/repos": "./src/tools/repos/index.ts",
    "./tools/schedules": "./src/tools/schedules/index.ts",
    "./tools/skills": "./src/tools/skills/index.ts",
    "./tools/swarm-config": "./src/tools/swarm-config/index.ts",
    "./tools/tracker": "./src/tools/tracker/index.ts",
    "./tools/workflows": "./src/tools/workflows/index.ts",
    "./tools/*": "./src/tools/*.ts",
    "./heartbeat/*": "./src/heartbeat/*.ts",
    "./script-workflows/*": "./src/script-workflows/*.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "tsc:check": "bun tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test src --pass-with-no-tests"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@asteasolutions/zod-to-openapi": "^8.0.0",
    "@desplega.ai/business-use": "^0.4.2",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@swarm/ai-llm": "workspace:*",
    "@swarm/ai-pricing": "workspace:*",
    "@swarm/artifacts": "workspace:*",
    "@swarm/core-utils": "workspace:*",
    "@swarm/integrations": "workspace:*",
    "@swarm/mcp-tool": "workspace:*",
    "@swarm/otel": "workspace:*",
    "@swarm/prompt-templates": "workspace:*",
    "@swarm/scripts": "workspace:*",
    "@swarm/storage": "workspace:*",
    "@swarm/types": "workspace:*",
    "@swarm/workflows": "workspace:*",
    "cron-parser": "^5.4.0",
    "date-fns": "^4.1.0",
    "zod": "4.2.1"
  }
}
